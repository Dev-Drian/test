# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=3010
NODE_ENV=development

# URL pública del servidor (para webhooks de Wompi)
# En desarrollo: usar ngrok → ver docs/PENDIENTE.md sección 5
# En producción: tu dominio real (https://tu-dominio.com)
APP_PUBLIC_URL=http://localhost:3010

# ===================================
# COUCHDB CONFIGURATION (REQUERIDO)
# ===================================
# Formato: http://usuario:password@host:puerto
COUCHDB_URL=http://admin:password@127.0.0.1:5984
DB_PREFIX=chatbot_

# ===================================
# AUTH (REQUERIDO)
# ===================================
# CRÍTICO: Cambiar en producción. Generar con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTO_EN_PRODUCCION_MINIMO_48_CHARS

# ===================================
# OPENAI API (REQUERIDO)
# ===================================
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-TU_KEY_AQUI
DEFAULT_AI_MODEL=gpt-4o-mini

# ===================================
# CORS (OPCIONAL)
# ===================================
# URLs permitidas separadas por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3021

# ===================================
# GOOGLE OAUTH (OPCIONAL)
# ===================================
# Para integración con Google Calendar y Sheets
# Obtén las credenciales en: https://console.cloud.google.com/
# Ver docs/GOOGLE_OAUTH_SETUP.md para instrucciones detalladas
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
CORS_ORIGINS=http://localhost:5173,http://localhost:3020,http://localhost:3021
# ===================================
# WOMPI (Colombia) - SANDBOX (pruebas)
# ===================================
PAYMENT_PROVIDER=wompi
WOMPI_PUBLIC_KEY=pub_test_AnjRyoWHPu9UW2X3AsXdz5tWyRAljVfU
WOMPI_PRIVATE_KEY=prv_test_TC7QYes8DCVl9VgjYYcIXcpIZk91jsfi
WOMPI_EVENTS_SECRET=test_events_FkA3jAe6sj8cMMu0mjrJCPxROKYOlT4k
WOMPI_INTEGRITY_SECRET=test_integrity_VQ6cWizafuU87pF77fwfTfjGnGc1kaid

# ===================================
# CONFIGURACIÓN DE PAGOS
# ===================================
PAYMENT_PROVIDER=wompi
PAYMENT_DEFAULT_CURRENCY=COP

# ===================================
# EMAIL TRANSACCIONAL (futuro)
# ===================================
# Recomendado: Resend (https://resend.com) — free tier 3000/mes
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@tu-dominio.com
# EMAIL_FROM_NAME=FlowAI

# ===================================
# META BUSINESS PLATFORM
# WhatsApp Business + Instagram Direct + Facebook Messenger
# ===================================
# Doc oficial: https://developers.facebook.com/docs/whatsapp/cloud-api

# 1. Crear app en https://developers.facebook.com → Mis apps → Crear app → tipo "Empresa"
# 2. Agregar los productos: WhatsApp y/o Messenger

# Token de verificación — lo defines tú, se pega en el dashboard al registrar el webhook
# Puede ser cualquier texto, ej: "mi_token_secreto_2026"
META_VERIFY_TOKEN=DEFINIR_UN_STRING_SECRETO_CUALQUIERA

# App Secret — Dashboard Meta → Tu App → Configuración básica → App Secret
META_APP_SECRET=

# ── WhatsApp Cloud API ──────────────────────────────────────────────────────
# Dashboard Meta → WhatsApp → Primeros pasos
# "Token de acceso temporal" (luego se vuelve permanente en Tokens del sistema)
META_WHATSAPP_TOKEN=
# "ID de número de teléfono" que aparece en la misma pantalla
META_WHATSAPP_PHONE_NUMBER_ID=

# ── Facebook Messenger ──────────────────────────────────────────────────────
# Dashboard Meta → Messenger → Configuración → Token de acceso de página
META_PAGE_TOKEN=

# ── Instagram Direct ────────────────────────────────────────────────────────
# Generalmente el mismo token que META_PAGE_TOKEN (si la página tiene IG conectado)
META_INSTAGRAM_TOKEN=

# Workspace por defecto si la URL del webhook no incluye ?workspaceId=
META_DEFAULT_WORKSPACE_ID=

# URL del webhook para pegar en el dashboard de Meta:
#   https://TU_DOMINIO/api/webhooks/meta?workspaceId=TU_WORKSPACE_ID
# En desarrollo usar ngrok:
#   https://SUBDOMINIO.ngrok-free.app/api/webhooks/meta?workspaceId=dulce-momento
# Suscribirse a los eventos: messages, messaging_postbacks
